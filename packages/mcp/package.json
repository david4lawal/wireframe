{
  "name": "@wframe/mcp",
  "version": "1.0.0",
  "description": "Wireframe MCP server: let a coding agent record sessions against a black-box target THROUGH Wireframe, compile a deterministic driver, and run a learned sub-workflow with ZERO model calls via a single tool.",
  "license": "MIT",
  "author": "David Lawal",
  "homepage": "https://wframe.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/david4lawal/wireframe.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/david4lawal/wireframe/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "agents",
    "claude",
    "deterministic",
    "protocol",
    "state-machine"
  ],
  "type": "module",
  "bin": {
    "wframe-mcp": "./dist/server.js"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "demo": "node dist/demo.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@wframe/core": "^1.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  }
}
