{
  "name": "@wireframe/core",
  "version": "1.0.0",
  "description": "Infer a protocol state machine from black-box agent sessions, compile a safe deterministic driver, and prove it. No LLM on the learned path.",
  "license": "MIT",
  "author": "David Lawal",
  "homepage": "https://wframe.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/david4lawal/wireframe.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/david4lawal/wireframe/issues"
  },
  "keywords": [
    "agents",
    "llm",
    "protocol",
    "state-machine",
    "automata-learning",
    "deterministic",
    "fsm",
    "mcp"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
