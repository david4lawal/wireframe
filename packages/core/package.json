{
  "name": "@wframe/core",
  "version": "1.3.0",
  "description": "Infer a protocol state machine from black-box agent sessions, compile a safe deterministic driver, and prove it. No LLM on the learned path.",
  "license": "MIT",
  "author": "David Lawal",
  "homepage": "https://wframe.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/david4lawal/wireframe.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/david4lawal/wireframe/issues"
  },
  "keywords": [
    "agents",
    "llm",
    "protocol",
    "state-machine",
    "automata-learning",
    "deterministic",
    "fsm",
    "mcp"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "demo:coffee": "tsx demos/coffee-demo.ts",
    "demo:http": "tsx demos/http-demo.ts",
    "demo:smtp": "tsx demos/smtp-demo.ts",
    "demo:smtp:real": "tsx demos/smtp-real-demo.ts",
    "demo:postgres:real": "tsx demos/postgres-real-demo.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.20.0",
    "@types/smtp-server": "^3.5.13",
    "@types/ws": "^8.5.10",
    "pg": "^8.22.0",
    "pg-gateway": "^0.3.0-beta.4",
    "smtp-server": "^3.19.1",
    "tsx": "^4.19.2",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
